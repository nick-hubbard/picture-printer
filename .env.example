# Leave blank to use the system default printer.
PRINTER_NAME=

# Set to false when you are ready to send jobs to the printer.
PRINT_DRY_RUN=true

# App port.
PORT=3000

# Use 0.0.0.0 to allow devices on the same network to open the app.
HOST=0.0.0.0

# Google Photos Picker API OAuth credentials.
# Create a Web application OAuth client and add this redirect URI:
# http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
